{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -lc 'root=$(git rev-parse --show-toplevel 2>/dev/null || pwd); TOKEN_OPTIMIZER_RUNTIME=codex bash \"$root/hooks/python-launcher.sh\" \"$root/hooks/run.py\" skills/token-optimizer/scripts/codex_hook_bridge.py session-start'",
            "timeout": 15
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -lc 'root=$(git rev-parse --show-toplevel 2>/dev/null || pwd); TOKEN_OPTIMIZER_RUNTIME=codex bash \"$root/hooks/python-launcher.sh\" \"$root/hooks/run.py\" skills/token-optimizer/scripts/codex_hook_bridge.py user-prompt-submit'",
            "timeout": 12
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash -lc 'root=$(git rev-parse --show-toplevel 2>/dev/null || pwd); TOKEN_OPTIMIZER_RUNTIME=codex bash \"$root/hooks/python-launcher.sh\" \"$root/hooks/run.py\" skills/token-optimizer/scripts/context_intel.py --quiet'",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash -lc 'root=$(git rev-parse --show-toplevel 2>/dev/null || pwd); TOKEN_OPTIMIZER_RUNTIME=codex bash \"$root/hooks/python-launcher.sh\" \"$root/hooks/run.py\" skills/token-optimizer/scripts/archive_result.py --quiet >/dev/null 2>&1'",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -lc 'root=$(git rev-parse --show-toplevel 2>/dev/null || pwd); TOKEN_OPTIMIZER_RUNTIME=codex bash \"$root/hooks/python-launcher.sh\" \"$root/hooks/run.py\" skills/token-optimizer/scripts/measure.py session-end-flush --trigger stop --quiet'",
            "timeout": 45
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash -lc 'root=$(git rev-parse --show-toplevel 2>/dev/null || pwd); TOKEN_OPTIMIZER_RUNTIME=codex bash \"$root/hooks/python-launcher.sh\" \"$root/hooks/run.py\" skills/token-optimizer/scripts/bash_hook.py --quiet'",
            "timeout": 8
          }
        ]
      }
    ]
  }
}
